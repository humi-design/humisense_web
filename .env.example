# HUMISENSE Environment Configuration
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=generate-a-secure-random-string-here-at-least-32-chars

# Database Configuration (MySQL on cPanel)
# Format: mysql://mysql_user:mysql_password@localhost/mysql_database?charset=utf8mb4
DATABASE_URL=mysql://CPANEL_USER_humisense:YOUR_PASSWORD@localhost/CPANEL_USER_humisense_db?charset=utf8mb4

# Mail Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
